    <!-- User Menu Content (MSA) -->
    <string name="user_menu_content">
        يمكنكم مناداة المساعد بكلمة \"يا بنتي\" ثم طلب أحد الأوامر التالية:\n\n
        • التحكم في التكييف: \"شغل التكييف\" أو \"ارفع درجة الحرارة\"\n
        • الملاحة: \"اذهب إلى المنزل\" أو \"أقرب محطة وقود\"\n
        • المكالمات: \"اتصل بأحمد\" أو \"رد على المكالمة\"\n
        • الوسائط: \"شغل الموسيقى\" أو \"الأغنية التالية\"\n
        • معلومات: \"كم الساعة الآن\" أو \"ما هي حالة البطارية\"
    </string>

