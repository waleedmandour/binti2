# Binti2 B2 Cloud Storage Configuration
# 
# Copy this file to b2_config.env and fill in your credentials
# Then run: python scripts/upload_to_b2.py
#
# Get your credentials from: https://secure.backblaze.com/appkeys.htm

# Your B2 Key ID (starts with 00...)
B2_KEY_ID=

# Your B2 Application Key (40+ characters)
B2_APP_KEY=

# Bucket name (default: binti2-models)
B2_BUCKET=binti2-models
