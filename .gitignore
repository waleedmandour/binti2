# ===========================================
# Binti-specific ignores
# ===========================================

# AI Models (downloaded from GitHub Releases)
app/src/main/assets/models/**/*.tflite
app/src/main/assets/models/**/*.onnx
app/src/main/assets/models/**/*.bin

# Voice packs (downloaded from GitHub Releases)
app/src/main/assets/voices/**/*.zip
app/src/main/assets/voices/**/*.onnx

# Keep placeholder files
!app/src/main/assets/models/**/*.placeholder
!app/src/main/assets/voices/**/*.placeholder

# Debug APKs for distribution
*.apk

# Release signing config (use GitHub Secrets instead)
keystore.properties
release-keystore.jks

# Test recordings
test_recordings/
*.wav
*.mp3
*.ogg

# Model training artifacts
training/
checkpoints/
logs/

# Documentation builds
docs/_build/
site/

